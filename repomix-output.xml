              >
                PROCEED TO LOGIN
              </button>
              <button 
                onClick={() => setShowLoginPrompt(false)}
                className="w-full bg-gray-100 text-gray-600 py-4 rounded-2xl font-black hover:bg-gray-200 transition"
              >
                CONTINUE BROWSING
